        <p><?= isset($error) ? $error : "" ?></p>

        <form action="?page=<?= ($_GET["page"]==="create") ? "create&type=" . htmlspecialchars($_GET["type"]) : "edit&type=" . htmlspecialchars($_GET["type"]) . "&id=" . htmlspecialchars($_GET["id"] ?? "") ?>" method="POST" enctype="multipart/form-data">

