                            <img src="<?= htmlspecialchars($picture->getLink()) ?>" alt="">
                            <a href="?page=edit&type=project&id=<?= htmlspecialchars($project->getId()) ?>&delete=<?= htmlspecialchars($picture->getId()) ?>" class="btn">Supprimer</a>
                        </article>
                    <?php endforeach; ?>
                <?php endif; ?>


            </div>

