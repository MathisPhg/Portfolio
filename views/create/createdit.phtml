                <?php endforeach; ?>


            </select>
            
            <label for="skills">Compétences </label>
            <article class="Skills_Checkbox">

                <?php foreach ($skills as $skill) : ?>
                    <label class="Skills">
                        <input type="checkbox" name="skills[]" value="<?= htmlspecialchars($skill->getId()) ?>" <?= ($_GET["page"] === "edit" && in_array($skill->getId(), $selectedSkillIds)) ? 'checked' : '' ?>><?= htmlspecialchars($skill->getName()) ?>
                    </label>
                <?php endforeach; ?>

            </article>


            <label for="Project_Images" class="Add_Image">Ajouter des images</label>
            <input type="file" class="Project_Images" id="Project_Images" name="Project_Images[]" accept="image/*" multiple >

